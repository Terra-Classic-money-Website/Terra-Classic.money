{
  "name": "terra-classic-money",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run i18n:generate && vite --host 127.0.0.1",
    "clean:metadata": "node scripts/clean-local-metadata.mjs",
    "i18n:generate": "node scripts/generate-i18n-html.mjs",
    "i18n:validate": "node scripts/validate-i18n.mjs",
    "i18n:report": "node scripts/report-i18n.mjs",
    "i18n:audit-rendered": "node scripts/audit-rendered-i18n.mjs",
    "assets:build": "node scripts/build-images.mjs",
    "assets:avatars": "node scripts/localize-avatars.mjs",
    "analytics:generate": "node scripts/generate-website-analytics.mjs",
    "build": "npm run i18n:generate && npm run i18n:validate && npm run clean:metadata && npm run assets:build && tsc -b && vite build",
    "typecheck": "tsc -b --pretty",
    "preview": "vite preview --host 127.0.0.1",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "perf:lh-budget": "node scripts/check-lighthouse-budget.mjs",
    "perf:audit": "node scripts/perf-audit.mjs && npm run perf:lh-budget",
    "visual:snapshots": "npm run build && node scripts/visual-regression.mjs",
    "visual:baseline": "npm run build && VISUAL_UPDATE_BASELINE=1 node scripts/visual-regression.mjs",
    "check": "npm run build && npm run i18n:audit-rendered && npm run perf:budget"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
